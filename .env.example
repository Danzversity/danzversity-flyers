# Copy to .env and fill in values
# All keys documented in Confluence Credentials Inventory (page 467599362)
#
# NOTE (v10 hybrid): the compose pipeline DOES use Remove.bg (person cutout) and
# optionally Ideogram (in-tool background generation). Code provides the locked
# chassis; AI/photos provide the visuals. Keys below.

# Google Drive — service-account JSON on a single line.
# The FLYERS root folder must be shared WITH this service account (service
# accounts have no storage quota of their own).
GOOGLE_SERVICE_ACCOUNT=

# Optional: id of the shared FLYERS root folder. Set this to skip the name
# lookup (faster + unambiguous). If unset, the tool finds a folder named FLYERS
# that's shared with the service account.
FLYERS_ROOT_FOLDER_ID=

# Library folder ids — the _backgrounds and _people folders inside FLYERS.
# Without these (or without the SA), the tool falls back to local library/ dirs.
BG_FOLDER_ID=
PEOPLE_FOLDER_ID=

# Remove.bg — person-photo cutout. Without it, photos composite with their
# original background (no crash, just uncut). ~$0.20/call, cached by photo hash.
REMOVEBG_API_KEY=

# Ideogram — OPTIONAL, only for generating new backgrounds inside the tool.
# Backgrounds normally come from the approved Drive library, so this can stay blank.
IDEOGRAM_API_KEY=

# Server
PORT=3001

# Production CORS allowlist (comma-separated), e.g. https://flyers.danzversity.com
# Defaults to * for local dev.
CORS_ORIGIN=

# Optional password gate. Set FLYERS_PASSWORD to require basic-auth on the whole
# app (/health stays open for platform health checks). FLYERS_USER defaults to
# "danzversity". Leave password blank for an open tool (fine behind a private URL).
FLYERS_USER=
FLYERS_PASSWORD=
